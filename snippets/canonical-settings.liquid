{% assign current_host = request.origin %}

{% if collection.url contains '/collections/thickness-16mm' %}
  <link rel="canonical" href="{{ current_host }}{{ collection.url | split: '?' | first }}" />

{% elsif collection.metafields.custom.seo_canonical_url != blank %}
  <link rel="canonical" href="{{ collection.metafields.custom.seo_canonical_url }}" />

{% elsif links contains current_url %}
  <link rel="canonical" href="{{ current_host }}/collections/paddles" />
  {% elsif canonical_url contains 'collections' %}
  <link rel="canonical" href="{{ current_host }}{{ collection.url }}" />
  {% else %}
  <link rel="canonical" href="{{ canonical_url }}" />
{% endif %}


