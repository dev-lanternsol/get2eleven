{{ 'section-quick-links.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
    .section-target-{{ section.id }}.section_boxed_1262 {
      max-width: 1262px;
      margin: 0 auto;
    }
  }

  .quick-links-{{ section.id }} .quick-links__blocks {
    gap: {{ section.settings.gap_desktop }}px;
  }

  @media screen and (max-width: 749px) {
    .quick-links-{{ section.id }} .quick-links__blocks {
      gap: {{ section.settings.gap_mobile }}px;
    }
  }
{%- endstyle -%}

<div class="quick-links quick-links-{{ section.id }} section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="quick-links__container {% if section.settings.section_width == 'boxed' %}section-target-{{ section.id }} section_boxed_1262{% else %}page-width{% endif %}">
    <div class="quick-links__header">
      {%- if section.settings.title != blank -%}
        <div class="quick-links__title">
          {%- if section.settings.title_mobile != blank -%}
            <div class="small-hide">{{ section.settings.title }}</div>
            <div class="medium-hide large-up-hide">{{ section.settings.title_mobile }}</div>
          {%- else -%}
            {{ section.settings.title }}
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.link_label != blank -%}
        <a href="{{ section.settings.link_url | default: '#' }}" class="quick-links__link">
          {{ section.settings.link_label }}
        </a>
      {%- endif -%}
    </div>

    <div class="quick-links__blocks">
      {%- for block in section.blocks -%}
        {%- if block.settings.label != blank -%}
          <a
            href="{{ block.settings.url | default: '#' }}"
            class="quick-links__block"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.label }}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Quick Links",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "richtext",
      "id": "title",
      "label": "Heading (Desktop)",
      "default": "<p>Quick Links</p>"
    },
    {
      "type": "richtext",
      "id": "title_mobile",
      "label": "Heading (Mobile)"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "View all"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "select",
      "id": "section_width",
      "options": [
        {
          "value": "full-width",
          "label": "Full width"
        },
        {
          "value": "boxed",
          "label": "Boxed (1262px)"
        }
      ],
      "default": "boxed",
      "label": "Section width"
    },
    {
      "type": "header",
      "content": "Gaps"
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Gap between blocks (Desktop)",
      "default": 10
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Gap between blocks (Mobile)",
      "default": 10
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top (Desktop)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (Desktop)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top (Mobile)",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (Mobile)",
      "default": 28
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Link label"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quick Links",
      "blocks": [
        { "type": "link", "settings": { "label": "Link 1" } },
        { "type": "link", "settings": { "label": "Link 2" } },
        { "type": "link", "settings": { "label": "Link 3" } }
      ]
    }
  ]
}
{% endschema %}
