        {
          "type": "select",
          "id": "title_size",
          "label": "Title size",
          "options": [
            { "value": "f_14", "label": "Small" },
            { "value": "f_16", "label": "Medium" },
            { "value": "f_18", "label": "Large" }
          ],
          "default": "f_18"
        },
        {
          "type": "select",
          "id": "text_size",
          "label": "Text size",
          "options": [
            { "value": "f_14", "label": "Small" },
            { "value": "f_16", "label": "Medium" },
            { "value": "f_18", "label": "Large" }
