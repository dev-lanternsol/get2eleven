{{ 'section-multicolumn.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  {%- liquid
    assign column_gap = section.settings.column_gap
    assign row_gap = section.settings.row_gap
  -%}

  .section-{{ section.id }}-padding {
    {% if column_gap > 0 %}
      --grid-desktop-horizontal-spacing: {{ column_gap }}px;
      --grid-mobile-horizontal-spacing: {{ column_gap }}px;
    {% endif %}
    {% if row_gap > 0 %}
      --grid-desktop-vertical-spacing: {{ row_gap }}px;
      --grid-mobile-vertical-spacing: {{ row_gap }}px;
    {% endif %}
  }

  .section-{{ section.id }}-padding .multicolumn-list {
    column-gap: var(--grid-desktop-horizontal-spacing) !important;
    row-gap: var(--grid-desktop-vertical-spacing) !important;
    justify-content: {{ section.settings.horizontal_alignment }} !important;
  }

  .section-{{ section.id }}-padding .title-wrapper-with-link .title {
    margin-bottom: {{ section.settings.margin_bottom_mobile }}px !important;
  }
  {%- if section.settings.heading_size_mobile contains 'f_' -%}
    .section-{{ section.id }}-padding .title-wrapper-with-link .title {
      font-size: {{ section.settings.heading_size_mobile | replace: 'f_', '' | append: 'px' }} !important;
    }
  {%- endif -%}

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding .title-wrapper-with-link .title {
      margin-bottom: {{ section.settings.margin_bottom }}px !important;
    }
    {%- if section.settings.heading_size contains 'f_' -%}
      .section-{{ section.id }}-padding .title-wrapper-with-link .title {
        font-size: {{ section.settings.heading_size | replace: 'f_', '' | append: 'px' }} !important;
      }
    {%- endif -%}
  }

  /* Multicolumn slider: hide arrows */
  .multicolumn--hide-arrows .slider-buttons .slider-button {
    display: none;
  }
  /* Multicolumn slider: hide dots */
  .multicolumn--hide-dots .multicolumn-slider-dots {
    display: none;
  }
  /* Multicolumn slider: hide counter */
  .multicolumn--hide-counter .slider-buttons .slider-counter {
    display: none;
  }

  /* Multicolumn slider buttons: remove margin */
  .section-{{ section.id }}-padding .slider-buttons {
    margin-top: 0 !important;
  }

  /* Multicolumn slider dots */
  .multicolumn-slider-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.6rem;
    padding: 0.4rem 0 0;
  }
  .multicolumn-slider-dot {
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    border: none;
    background: #E5E7EB;
    padding: 0;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }
  .multicolumn-slider-dot.active {
    background-color: #33A9FE;
  }
{%- endstyle -%}

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and section.blocks.size > columns_mobile_int
    assign show_mobile_slider = true
  endif
-%}

<div class="multicolumn color-{{ section.settings.color_scheme }} gradient{% unless section.settings.background_style == 'none' and settings.text_boxes_border_thickness > 0 or settings.text_boxes_shadow_opacity > 0 %} background-{{ section.settings.background_style }}{% endunless %}{% if section.settings.title == blank %} no-heading{% endif %}">
  <div
    class="{% if section.settings.section_width == 'boxed' %}section_boxed_1260{% else %}page-width{% endif %} section-{{ section.id }}-padding isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}
      data-cascade
    {% endif %}
  >
    {%- unless section.settings.title == blank -%}
      <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin">
        {% assign heading_tag = section.settings.heading_tag | default: 'h2' %}
        {%- liquid
          assign heading_content = section.settings.title | replace: '<p>', '' | replace: '</p>', ''
        -%}
        <{{ heading_tag }} class="title {{ section.settings.heading_size }}">
          {{ heading_content }}
        </{{ heading_tag }}>
        {%- if section.settings.description != blank -%}
          <div class="multicolumn__description rte">
            {{ section.settings.description }}
          </div>
        {%- endif -%}
        {%- if section.settings.button_label != blank and show_mobile_slider -%}
          <a href="{{ section.settings.button_link }}" class="link underlined-link large-up-hide">
            {{- section.settings.button_label | escape -}}
          </a>
        {%- endif -%}
      </div>
    {%- endunless -%}
    <slider-component
      class="slider-mobile-gutter{% unless section.settings.show_arrows %} multicolumn--hide-arrows{% endunless %}{% unless section.settings.show_dots %} multicolumn--hide-dots{% endunless %}{% unless section.settings.show_counter %} multicolumn--hide-counter{% endunless %}"
      data-section-id="{{ section.id }}"
    >
      <ul
        class="multicolumn-list contains-content-container grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop{% if show_mobile_slider %} slider slider--tablet grid--peek{% endif %}"
        id="Slider-{{ section.id }}"
        role="list"
      >
        {%- liquid
          assign highest_ratio = 0
          for block in section.blocks
            if block.settings.image.aspect_ratio > highest_ratio
              assign highest_ratio = block.settings.image.aspect_ratio
            endif
          endfor
        -%}
        {%- for block in section.blocks -%}
          {%- assign empty_column = '' -%}
          {%- if block.settings.image == blank
            and block.settings.title == blank
            and block.settings.text == blank
            and block.settings.link_label == blank
          -%}
            {%- assign empty_column = ' multicolumn-list__item--empty' -%}
          {%- endif -%}

          <li
            id="Slide-{{ section.id }}-{{ forloop.index }}"
            class="multicolumn-list__item grid__item{% if section.settings.swipe_on_mobile %} slider__slide{% endif %}{% if section.settings.column_alignment == 'center' %} center{% endif %}{{ empty_column }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            <div class="multicolumn-card content-container{% if block.settings.color_scheme != section.settings.color_scheme %} color-{{ block.settings.color_scheme }} gradient{% endif %}">
              {%- if block.settings.image != blank -%}
                {%- liquid
                  assign spaced_image = false
                  if section.settings.image_ratio == 'adapt' or section.settings.image_ratio == 'circle' or section.settings.image_ratio == 'icon'
                    assign spaced_image = true
                  endif
                -%}
                <div class="multicolumn-card__image-wrapper multicolumn-card__image-wrapper--{{ section.settings.image_width }}-width{% if section.settings.image_width != 'full' or spaced_image %} multicolumn-card-spacing{% endif %}">
                  <div
                    class="media media--transparent media--{{ section.settings.image_ratio }}"
                    {% if section.settings.image_ratio == 'adapt' %}
                      style="padding-bottom: {{ 1 | divided_by: highest_ratio | times: 100 }}%;"
                    {% elsif section.settings.image_ratio == 'icon' %}
                      style="padding-bottom: 40px;"
                    {% endif %}
                  >
                    {%- liquid
                      assign number_of_columns = section.settings.columns_desktop
                      assign number_of_columns_mobile = section.settings.columns_mobile
                      assign grid_space_desktop = number_of_columns | minus: 1 | times: settings.spacing_grid_horizontal | plus: 100 | append: 'px'
                      assign grid_space_tablet = number_of_columns_mobile | minus: 1 | times: settings.spacing_grid_horizontal | plus: 100 | append: 'px'
                      assign grid_space_mobile = number_of_columns_mobile | minus: 1 | times: settings.spacing_grid_horizontal | divided_by: 2 | plus: 30 | append: 'px'
                      if section.settings.image_width == 'half'
                        assign image_width = 0.5
                      elsif section.settings.image_width == 'third'
                        assign image_width = 0.33
                      else
                        assign image_width = 1
                      endif
                    -%}
                    {% capture sizes %}
                      (min-width: {{ settings.page_width }}px) calc(({{ settings.page_width }}px - {{ grid_space_desktop }}) * {{ image_width }} /  {{ number_of_columns }}),
                      (min-width: 990px) calc((100vw - {{ grid_space_desktop }}) * {{ image_width }} / {{ number_of_columns }}),
                      (min-width: 750px) calc((100vw - {{ grid_space_tablet }}) * {{ image_width }} / {{ number_of_columns_mobile }}),
                      calc((100vw - {{ grid_space_mobile }}) * {{ image_width }} / {{ number_of_columns_mobile }})
                    {% endcapture %}
                    {{
                      block.settings.image
                      | image_url: width: 3200
                      | image_tag:
                        widths: '50, 75, 100, 150, 200, 300, 400, 500, 750, 1000, 1250, 1500, 1750, 2000, 2250, 2500, 2750, 3000, 3200',
                        sizes: sizes,
                        class: 'multicolumn-card__image'
                    }}
                  </div>
                </div>
              {%- endif -%}
              <div class="multicolumn-card__info">
                {%- if block.settings.title != blank -%}
                  {% assign column_heading_tag = block.settings.heading_tag | default: 'h3' %}
                  <{{ column_heading_tag }} class="inline-richtext">
                    {{- block.settings.title -}}
                  </{{ column_heading_tag }}>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="rte">{{ block.settings.text }}</div>
                {%- endif -%}
                {%- if block.settings.link_label != blank -%}
                  <a
                    class="link animate-arrow"
                    {% if block.settings.link == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ block.settings.link }}"
                    {% endif %}
                  >
                    {{- block.settings.link_label | escape -}}
                    <span class="icon-wrap">&nbsp;{% render 'icon-arrow' %}</span></a
                  >
                {%- endif -%}
              </div>
            </div>
          </li>
        {%- endfor -%}
      </ul>

      {%- if show_mobile_slider -%}
        <div class="slider-buttons no-js-hidden large-up-hide">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            {% render 'icon-caret' %}
          </button>
          <div class="slider-counter caption">
            <span class="slider-counter--current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
            <span class="slider-counter--total">{{ section.blocks.size }}</span>
          </div>
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            {% render 'icon-caret' %}
          </button>
        </div>
        <div class="multicolumn-slider-dots no-js-hidden large-up-hide" data-slider-dots="{{ section.id }}"></div>
      {%- endif -%}
    </slider-component>
    <div class="center{% if show_mobile_slider %} small-hide medium-hide{% endif %}">
      {%- if section.settings.button_label != blank -%}
        <a
          class="button button--primary"
          {% if section.settings.button_link == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ section.settings.button_link }}"
          {% endif %}
        >
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{%- if show_mobile_slider -%}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const sectionId = '{{ section.id }}';
      const sliderEl = document.getElementById('Slider-' + sectionId);
      const dotsContainer = document.querySelector('[data-slider-dots="' + sectionId + '"]');
      if (!sliderEl || !dotsContainer) return;

      const slides = sliderEl.querySelectorAll('[id^="Slide-' + sectionId + '-"]');
      if (slides.length < 2) return;

      function getSlidesPerPage() {
        if (slides.length < 2) return 1;
        var offset = slides[1].offsetLeft - slides[0].offsetLeft;
        return Math.floor(sliderEl.clientWidth / offset) || 1;
      }

      function getTotalPages() {
        return slides.length - getSlidesPerPage() + 1;
      }

      function getCurrentPage() {
        if (slides.length < 2) return 1;
        var offset = slides[1].offsetLeft - slides[0].offsetLeft;
        return Math.round(sliderEl.scrollLeft / offset) + 1;
      }

      function createDots() {
        dotsContainer.innerHTML = '';
        var totalPages = getTotalPages();
        if (totalPages < 2) {
          dotsContainer.innerHTML = '';
          return;
        }
        var currentPage = getCurrentPage();
        for (var i = 1; i <= totalPages; i++) {
          var dot = document.createElement('button');
          dot.classList.add('multicolumn-slider-dot');
          dot.setAttribute('aria-label', 'Go to slide ' + i);
          if (i === currentPage) dot.classList.add('active');
          (function (page) {
            dot.addEventListener('click', function () {
              var offset = slides[1].offsetLeft - slides[0].offsetLeft;
              sliderEl.scrollTo({ left: (page - 1) * offset, behavior: 'smooth' });
            });
          })(i);
          dotsContainer.appendChild(dot);
        }
      }

      function updateDots() {
        var dots = dotsContainer.querySelectorAll('.multicolumn-slider-dot');
        var currentPage = getCurrentPage();
        dots.forEach(function (dot, index) {
          dot.classList.toggle('active', index + 1 === currentPage);
        });
      }

      sliderEl.addEventListener('scroll', function () {
        requestAnimationFrame(updateDots);
      });

      createDots();

      var resizeTimer;
      window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function () {
          createDots();
        }, 250);
      });
    });
  </script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.multicolumn.name",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "richtext",
      "id": "title",
      "default": "<p>Multicolumn</p>",
      "label": "t:sections.multicolumn.settings.title.label"
    },
    {
      "type": "header",
      "content": "Margin Bottom"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Margin Bottom (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Margin Bottom (Mobile)",
      "default": 0
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "info": "Optional description text below the heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "f_28",
          "label": "Headline Large"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h1",
      "label": "Heading Size (Desktop)"
    },
    {
      "type": "select",
      "id": "heading_size_mobile",
      "options": [
        {
          "value": "f_14",
          "label": "Extra Compact Mobile"
        },
        {
          "value": "f_18",
          "label": "Compact Mobile"
        },
        {
          "value": "f_22",
          "label": "Standard Mobile"
        },
        {
          "value": "f_28",
          "label": "Headline Large Mobile"
        },
        {
          "value": "h2",
          "label": "Heading H2 Mobile"
        }
      ],
      "default": "f_22",
      "label": "Heading Size (Mobile)"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        }
      ],
      "default": "h2",
      "label": "Heading tag"
    },
    {
      "type": "select",
      "id": "image_width",
      "options": [
        {
          "value": "third",
          "label": "t:sections.multicolumn.settings.image_width.options__1.label"
        },
        {
          "value": "half",
          "label": "t:sections.multicolumn.settings.image_width.options__2.label"
        },
        {
          "value": "full",
          "label": "t:sections.multicolumn.settings.image_width.options__3.label"
        }
      ],
      "default": "full",
      "label": "t:sections.multicolumn.settings.image_width.label"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.multicolumn.settings.image_ratio.options__1.label"
