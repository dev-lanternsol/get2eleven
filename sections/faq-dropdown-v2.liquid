{% if section.settings.heading != blank %}
  <h2 class="text-center {{ section.settings.heading_size }}">
    {{ section.settings.heading }}
  </h2>
{% endif %}

<div class="collapsible-container">
  {% if section.settings.faq_metafield != blank %}
    {% assign faq_content = section.settings.faq_metafield %}
    {% assign questions = faq_content | split: "Q: " %}

    {% for question in questions %}
      {% if question != blank %}
        {% assign question_parts = question | split: "A: " %}
        {% if question_parts.size == 2 %}
          <details class="collapsible">
            <summary class="dropdown-header">
              <h3 class="{{ section.settings.question_size }}">{{ question_parts[0] | strip }}</h3>
              <svg
                class="collapsed"
                xmlns="http://www.w3.org/2000/svg"
                width="15.117"
                height="15.117"
                viewBox="0 0 15.117 15.117"
              >
                <g id="Grupo_1124" data-name="Grupo 1124" transform="translate(1 1)">
                  <path id="Trazado_449" data-name="Trazado 449" d="M7027.74,1021v13.117" transform="translate(-7020.74 -1021)" fill="none" stroke="black" stroke-linecap="round" stroke-width="2"/>
                  <path id="Trazado_450" data-name="Trazado 450" d="M0,0V13.117" transform="translate(0 6) rotate(-90)" fill="none" stroke="black" stroke-linecap="round" stroke-width="2"/>
                </g>
              </svg>
              <svg
                class="expanded"
                xmlns="http://www.w3.org/2000/svg"
                width="15.117"
                height="2"
                viewBox="0 0 15.117 2"
              >
                <g id="Grupo_1097" data-name="Grupo 1097" transform="translate(1 -5)">
                  <path id="Trazado_450" data-name="Trazado 450" d="M0,0V13.117" transform="translate(0 6) rotate(-90)" fill="none" stroke="black" stroke-linecap="round" stroke-width="2"/>
                </g>
              </svg>
            </summary>
            <div class="dropdown-content" style="max-height: unset;">
              <div class="rte">{{ question_parts[1] | strip }}</div>
            </div>
          </details>
        {% endif %}
      {% endif %}
    {% endfor %}
  {% endif %}
</div>

{% render 'dropdown-helper' %}

{% schema %}
{
  "name": "FAQ dropdown v2",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "select",
      "id": "question_size",
      "options": [
        {
          "value": "h5",
          "label": "Extra Small"
        },
        {
          "value": "h4",
          "label": "Small"
        },
        {
          "value": "h3",
          "label": "Medium"
        },
        {
          "value": "h2",
          "label": "Large"
        }
      ],
      "default": "h4",
      "label": "Question title size"
    },
    {
      "type": "richtext",
      "id": "faq_metafield",
      "label": "FAQ Content",
      "info": "Format: Q: Question text? A: Answer text. Separate multiple FAQs with new Q: sections."
    }
  ],
  "presets": [
    {
      "name": "FAQ dropdown v2"
    }
  ]
}
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

{% if section.settings.faq_metafield != blank %}
  {% assign faq_content = section.settings.faq_metafield %}
  {% assign questions = faq_content | split: "Q: " %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
     {% for question in questions %}
       {% if question != blank %}
         {% assign question_parts = question | split: "A: " %}
         {% if question_parts.size == 2 %}
      {
        "@type": "Question",
        "name": "{{ question_parts[0] | strip | strip_html }}",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "{{ question_parts[1] | strip | strip_html }}"
        }
      }{% unless forloop.last %},{% endunless %}
         {% endif %}
       {% endif %}
     {% endfor %}
    ]
  }
  </script>
{% endif %}
